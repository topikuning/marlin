# ─── DATABASE ────────────────────────────────────────────────────────────────
# Untuk local development (Docker):
DATABASE_URL=postgresql://knmp_user:knmp_secure_password@localhost:5432/knmp_monitor

# Untuk Supabase (production cloud):
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres

# ─── SECURITY ─────────────────────────────────────────────────────────────────
# WAJIB diganti sebelum deploy ke production!
# Generate dengan: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-minimum-32-characters-change-this

# ─── APP ─────────────────────────────────────────────────────────────────────
DEBUG=false

# ─── DOCKER ───────────────────────────────────────────────────────────────────
DB_PASSWORD=knmp_secure_password
